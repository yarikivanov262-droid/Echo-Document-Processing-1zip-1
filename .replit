modules = ["nodejs-20", "web", "bash"]

[deployment]
router = "application"
deploymentTarget = "autoscale"
run = ["sh", "-c", "PORT=8080 pnpm --filter @workspace/api-server run start & PORT=5000 BASE_PATH=/ API_PORT=8080 pnpm --filter @workspace/echo-messenger run preview"]
build = ["sh", "-c", "pnpm install && DATABASE_URL=$DATABASE_URL pnpm --filter @workspace/db run push && pnpm --filter @workspace/api-server run build && pnpm --filter @workspace/echo-messenger run build"]

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]

[agent]
stack = "BEST_EFFORT_FALLBACK"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 8080
externalPort = 8080

[userenv]

[userenv.shared]
VAPID_PUBLIC_KEY = "BDoCI_-V3VnoWI1pf4M4fxUtMCiq_8vd-nS7dnBlVp7Ucgbr_Qy11UUS2PaO6kKQPlrAYbZNDT2AV_-3bN5CaZk"
